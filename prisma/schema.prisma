// Preorder Manager - Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Preorder {
  id          String   @id @default(cuid())
  title       String
  sku         String
  customer    String
  quantity    Int
  price       Decimal
  description String?
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
